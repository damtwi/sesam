# Fortran settings
FC = mpiifort
LD = mpiifort
CPPFLAGS = -DMPI
CPPDEFS = -DMPI

NETCDF_INC = $(shell nf-config --fflags)
NETCDF_LIB = $(shell nf-config --flibs)

FFLAGS = -check all -fpic -132 -convert big_endian $(IDEV_PATH) \
         -I${HOME}/include_mpi \
         -I/linkhome/rech/genige01/utw56cf/ensdam-master/build/python/src \
         $(NETCDF_INC)

LDFLAGS = $(NETCDF_LIB) \
          -Wl,-rpath,$(HOME)/lib \
          -L$(HOME)/lib -lensdam_mpi


LIST =

